<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Provider Panel{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <style>
            body { background-color: #f4f7f6; overflow-x: hidden; }
            #sidebar { min-width: 250px; max-width: 250px; min-height: 100vh; transition: all 0.3s; background: #2c3e50; color: #fff; }
            .sidebar-header { padding: 20px; background: #1a252f; }
            #sidebar ul li a { padding: 15px 20px; display: block; color: #adb5bd; text-decoration: none; }
            #sidebar ul li a:hover, #sidebar ul li a.active { color: #fff; background: #34495e; border-left: 4px solid #2ecc71; }
            .content-area { width: 100%; padding: 30px; }
            .card-stat { border: none; border-radius: 15px; transition: transform 0.3s; }
            .card-stat:hover { transform: translateY(-5px); }
        </style>
    </head>
    <body>
        <div class="d-flex">
            <nav id="sidebar">
                <div class="sidebar-header text-center">
                    <h4 class="fw-bold text-success"><i class="fas fa-tools me-2"></i>Provider</h4>
                    <p class="small text-muted mb-0">{{ app.user.fullName }}</p>
                </div>
                <ul class="list-unstyled mt-3">
                    <li><a href="{{ path('app_provider_dashboard') }}" class="active"><i class="fas fa-home me-2"></i> Dashboard</a></li>
                    <li><a href="{{ path('app_service_new') }}"><i class="fas fa-plus-circle me-2"></i> Add Service</a></li>
                    <li><a href="#"><i class="fas fa-list me-2"></i> My Services</a></li>
                    <li><a href="#"><i class="fas fa-chart-line me-2"></i> Earnings</a></li>
                    <li class="mt-5"><a href="{{ path('app_logout') }}" class="text-danger"><i class="fas fa-sign-out-alt me-2"></i> Logout</a></li>
                </ul>
            </nav>

            <div class="content-area">
                {% block body %}{% endblock %}
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>