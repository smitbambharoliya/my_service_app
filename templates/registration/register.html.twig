{% extends 'base.html.twig' %}

{% block title %}Create Account - ServiceHub{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-4 bg-success text-white p-5 d-flex flex-column justify-content-center text-center">
                        <div class="mb-4">
                            <i class="fas fa-user-plus fa-4x mb-3 animate-bounce"></i>
                        </div>
                        <h2 class="fw-bold">Join Us!</h2>
                        <p class="opacity-75">Become a part of our community to find or provide local services easily.</p>
                        <hr class="w-25 mx-auto opacity-50">
                        <div class="mt-4 small">
                            <p><i class="fas fa-check-circle me-2"></i> Verified Providers</p>
                            <p><i class="fas fa-check-circle me-2"></i> Secure Bookings</p>
                            <p><i class="fas fa-check-circle me-2"></i> 24/7 Support</p>
                        </div>
                    </div>

                    <div class="col-md-8 p-4 p-md-5 bg-white">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="fw-bold mb-0">Personal Details</h3>
                            <span class="badge bg-light text-muted">Step 1 of 1</span>
                        </div>

                        {{ form_start(registrationForm, {'attr': {'class': 'needs-validation'}}) }}
                            
                            <div class="row g-3 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold small text-uppercase">Full Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
                                        {{ form_widget(registrationForm.fullName, {'attr': {'class': 'form-control border-start-0 bg-light', 'placeholder': 'John Doe'}}) }}
                                    </div>
                                    <div class="text-danger small">{{ form_errors(registrationForm.fullName) }}</div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-uppercase">Email Address</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                                        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control border-start-0 bg-light', 'placeholder': 'name@example.com'}}) }}
                                    </div>
                                    <div class="text-danger small">{{ form_errors(registrationForm.email) }}</div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-uppercase">Phone Number</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-phone text-muted"></i></span>
                                        {{ form_widget(registrationForm.mobile, {'attr': {'class': 'form-control border-start-0 bg-light', 'placeholder': '10-digit number'}}) }}
                                    </div>
                                    <div class="text-danger small">{{ form_errors(registrationForm.mobile) }}</div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-uppercase">I want to join as</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-briefcase text-muted"></i></span>
                                        {{ form_widget(registrationForm.roles, {'attr': {'class': 'form-select border-start-0 bg-light'}}) }}
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-uppercase">Password</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
                                        {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control border-start-0 bg-light', 'placeholder': '••••••••'}}) }}
                                    </div>
                                    <div class="text-danger small">{{ form_errors(registrationForm.plainPassword) }}</div>
                                </div>
                            </div>

                            <h5 class="fw-bold mb-3 border-bottom pb-2">Location & Others</h5>
                            
                            <div class="row g-3 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold small text-uppercase">Address</label>
                                    {{ form_widget(registrationForm.address, {'attr': {'class': 'form-control bg-light', 'placeholder': 'Your house/street address', 'rows': '2'}}) }}
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-uppercase">City</label>
                                    {{ form_widget(registrationForm.city, {'attr': {'class': 'form-control bg-light', 'placeholder': 'City'}}) }}
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-uppercase">Pincode</label>
                                    {{ form_widget(registrationForm.pincode, {'attr': {'class': 'form-control bg-light', 'placeholder': 'Pincode'}}) }}
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-uppercase">Date of Birth</label>
                                    {{ form_widget(registrationForm.dot, {'attr': {'class': 'form-control bg-light'}}) }}
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-uppercase">Gender</label>
                                    {{ form_widget(registrationForm.gender, {'attr': {'class': 'form-select bg-light'}}) }}
                                </div>
                            </div>

                            <div class="mb-4 form-check">
                                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                                <label class="form-check-label text-muted small">
                                    I agree to the <a href="#" class="text-decoration-none text-success fw-bold">Terms & Conditions</a>
                                </label>
                                <div class="text-danger small">{{ form_errors(registrationForm.agreeTerms) }}</div>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold shadow">
                                    Create My Account <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            </div>

                            <div class="text-center mt-4">
                                <p class="text-muted small mb-0">Already have an account? 
                                    <a href="{{ path('app_login') }}" class="text-success fw-bold text-decoration-none border-bottom border-success">Sign In</a>
                                </p>
                            </div>
                        {{ form_end(registrationForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh; }
    .card { border: none; }
    .input-group-text { border: none; }
    .form-control, .form-select { border: none; font-size: 0.95rem; }
    .form-control:focus, .form-select:focus { background-color: #fff !important; border-color: #28a745; box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.1); }
    .bg-success { background: linear-gradient(45deg, #28a745, #218838) !important; }
    
    .animate-bounce {
        animation: bounce 2s infinite;
    }
    @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
</style>
{% endblock %}