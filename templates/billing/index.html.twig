{% extends 'base.html.twig' %}

{% block title %}Billing History & Invoices{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h1 class="fw-bold"><i class="fas fa-file-invoice-dollar text-primary me-2"></i>Payment History</h1>
            <p class="text-muted">Manage your subscriptions and view your past transactions.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="{{ path('app_service_list') }}" class="btn btn-outline-secondary rounded-pill">
                <i class="fas fa-arrow-left me-1"></i> Back to Services
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-primary text-white">
                <div class="small text-uppercase opacity-75 fw-bold">Current Plan</div>
                <div class="h2 fw-bold mb-0">Premium Member</div>
                <i class="fas fa-crown position-absolute end-0 bottom-0 m-3 opacity-25 fa-3x"></i>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                <div class="small text-uppercase text-muted fw-bold">Total Transactions</div>
                <div class="h2 fw-bold mb-0 text-dark">{{ billings|length }}</div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="px-4 py-3">Transaction ID</th>
                            <th class="py-3">Date</th>
                            <th class="py-3">Amount</th>
                            <th class="py-3">Status</th>
                            <th class="px-4 py-3 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for bill in billings %}
                            <tr>
                                <td class="px-4">
                                    <code class="text-primary fw-bold">{{ bill.transactionId }}</code>
                                </td>
                                <td>{{ bill.createdAt|date('d M, Y') }}</td>
                                <td class="fw-bold text-dark">₹{{ bill.amount }}</td>
                                <td>
                                    <span class="badge rounded-pill px-3 py-2 
                                        {{ bill.paymentStatus == 'success' ? 'bg-success-light text-success' : 'bg-danger-light text-danger' }}">
                                        {{ bill.paymentStatus|upper }}
                                    </span>
                                </td>
                                <td class="px-4 text-end">
                                    <button class="btn btn-sm btn-light border rounded-pill">
                                        <i class="fas fa-download"></i> Receipt
                                    </button>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="fas fa-receipt fa-3x mb-3 opacity-25"></i>
                                        <p>No billing records found.</p>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-light { background-color: #e8f5e9; color: #2e7d32; }
    .bg-danger-light { background-color: #ffebee; color: #c62828; }
    .card { transition: transform 0.3s ease; }
    .card:hover { transform: translateY(-5px); }
    .table thead th { border: none; }
</style>
{% endblock %}