{% extends 'base.html.twig' %}

{% block title %}Billing & Subscription History{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h1 class="fw-bold text-dark"><i class="fas fa-file-invoice-dollar me-2 text-primary"></i>Billing History</h1>
            <p class="text-muted">Manage your premium subscriptions and track all payments.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <div class="card d-inline-block border-0 shadow-sm p-3 bg-light">
                <span class="text-muted d-block small text-uppercase fw-bold">Current Status</span>
                {% if app.user.isVerified %}
                    <span class="badge bg-success-soft text-success rounded-pill px-3 mt-1">
                        <i class="fas fa-check-circle me-1"></i> Active Member
                    </span>
                {% else %}
                    <span class="badge bg-secondary-soft text-secondary rounded-pill px-3 mt-1">Standard Account</span>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-3 mb-md-0 card-hover">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-primary-soft text-primary rounded-3 me-3">
                        <i class="fas fa-wallet fa-lg"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 small fw-bold">Total Spent</h6>
                        <h3 class="mb-0 fw-bold">₹{{ total_spent|default('0.00') }}</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-3 mb-md-0 card-hover">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-warning-soft text-warning rounded-3 me-3">
                        <i class="fas fa-crown fa-lg"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 small fw-bold">Active Plan</h6>
                        <h3 class="mb-0 fw-bold">Premium</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-white py-4 border-0">
            <h5 class="mb-0 fw-bold">Recent Transactions</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Transaction ID</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Receipt</th>
                    </tr>
                </thead>
                <tbody>
                    {% for bill in billings %}
                    <tr>
                        <td class="ps-4">
                            <span class="fw-bold text-dark">#{{ bill.transactionId }}</span>
                        </td>
                        <td>{{ bill.createdAt|date('M d, Y') }}</td>
                        <td class="fw-bold text-dark">₹{{ bill.amount }}</td>
                        <td>
                            {% if bill.paymentStatus == 'success' %}
                                <span class="badge bg-success-soft text-success rounded-pill">Completed</span>
                            {% else %}
                                <span class="badge bg-danger-soft text-danger rounded-pill">Failed</span>
                            {% endif %}
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                <i class="fas fa-download me-1"></i> PDF
                            </button>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076549.png" width="80" class="mb-3 opacity-50" alt="No data">
                            <p class="text-muted mb-0">Haji sudhi koi payment history nathi.</p>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Professional Soft UI Colors */
    .bg-primary-soft { background-color: rgba(13, 110, 253, 0.1); }
    .bg-success-soft { background-color: rgba(25, 135, 84, 0.1); }
    .bg-warning-soft { background-color: rgba(255, 193, 7, 0.1); }
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1); }
    .bg-secondary-soft { background-color: rgba(108, 117, 125, 0.1); }
    
    .icon-shape {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-hover {
        transition: all 0.3s ease;
    }
    .card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    .table thead th {
        font-weight: 600;
        letter-spacing: 0.5px;
        border-bottom: none;
    }
    
    .table tbody tr {
        transition: background-color 0.2s;
    }
</style>
{% endblock %}