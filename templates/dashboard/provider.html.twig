<h3>Your Billing History</h3>
<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Amount</th>
            <th>Transaction ID</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        {% for bill in app.user.billings %}
        <tr>
            <td>{{ bill.createdAt|date('Y-m-d') }}</td>
            <td>₹{{ bill.amount }}</td>
            <td>{{ bill.transactionId }}</td>
            <td><span class="badge bg-success">{{ bill.paymentStatus }}</span></td>
        </tr>
        {% endfor %}
    </tbody>
</table>