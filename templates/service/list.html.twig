{% extends 'base.html.twig' %}

{% block title %}All Services{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold">Available Services</h1>
        {% if is_granted('ROLE_PROVIDER') %}
            <a href="{{ path('app_service_new') }}" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="fas fa-plus me-1"></i> Add My Service
            </a>
        {% endif %}
    </div>

    <div class="row">
        {# Loop ahiya thi sharu thay che #}
        {% for service in services %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 {{ service.isPremium ? 'border-warning shadow-lg' : 'border-light shadow-sm' }} rounded-4">
                    
                    {% if service.isPremium %}
                        <div class="card-header bg-warning text-dark text-center fw-bold small">
                            ⭐ PREMIUM PARTNER
                        </div>
                    {% endif %}

                    <div class="card-body p-4">
                        {# AA LINE LOOP NI ANDAR J HOVI JOIE #}
                        <h5 class="card-title fw-bold text-uppercase">
                            {{ service.title }}
                            {% if service.isPremium %}
                                <span class="badge bg-warning text-dark ms-2" title="Verified Provider">
                                    <i class="fas fa-star"></i> Verified
                                </span>
                            {% endif %}
                        </h5>
                        
                        <h6 class="card-subtitle mb-3 text-muted">Category: {{ service.category }}</h6>
                        <p class="card-text text-muted small">{{ service.description }}</p>
                        <hr>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="h5 text-success mb-0 fw-bold">₹{{ service.price }}</span>
                            <a href="{{ path('app_service_book', {id: service.id}) }}" class="btn btn-outline-primary btn-sm rounded-pill px-3">Book Now</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="alert alert-info rounded-4 p-5 shadow-sm">
                    <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
                    <h4>No services available yet.</h4>
                </div>
            </div>
        {% endfor %}
        {# Loop ahiya khatam thay che #}
    </div>
</div>
{% endblock %}