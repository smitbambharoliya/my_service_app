{% extends 'base.html.twig' %}

{% block title %}All Services{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary">Available Services</h1>
        {# Jo user Provider hoy to j tene 'Add New' button dekhay #}
        {% if is_granted('ROLE_PROVIDER') %}
            <a href="{{ path('app_service_new') }}" class="btn btn-success">+ Add My Service</a>
        {% endif %}
    </div>

     <h5 class="card-title fw-bold text-uppercase">
            {{ service.title }}
               {% if service.isPremium %}
                 <span class="badge bg-warning text-dark ms-2" title="Verified Provider">
                    <i class="fas fa-star"></i> Verified
                </span>
            {% endif %}
     </h5>
    <div class="row">
        {% for service in services %}
            <div class="col-md-4 mb-4">
                {# Jo premium hoy to border gold thase #}
                <div class="card h-100 {{ service.isPremium ? 'border-warning shadow-lg' : 'border-light shadow-sm' }}">
                    
                    {% if service.isPremium %}
                        <div class="card-header bg-warning text-dark text-center fw-bold">
                            ⭐ PREMIUM PARTNER
                        </div>
                    {% endif %}

                    <div class="card-body">
                        <h5 class="card-title fw-bold text-uppercase">{{ service.title }}</h5>
                        <h6 class="card-subtitle mb-2 text-muted">Category: {{ service.category }}</h6>
                        <p class="card-text text-truncate-3">{{ service.description }}</p>
                        <hr>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 text-success mb-0">₹{{ service.price }}</span>
                            <span class="badge bg-info text-dark">By: {{ service.provider.email }}</span>
                        </div>
                    </div>
                    
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="#" class="btn btn-outline-primary w-100">Book Now</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <p class="alert alert-info">No services found. Be the first to add one!</p>
            </div>
        {% endfor %}
    </div>
</div>

<style>
    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .card { transition: transform 0.3s; }
    .card:hover { transform: translateY(-5px); }
</style>
{% endblock %}