{% extends 'base.html.twig' %}

{% block title %}Add New Service{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white p-4">
                    <h2 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Register Your Service</h2>
                    <small>Provide details about the service you offer to customers.</small>
                </div>
                <div class="card-body p-4">
                    {{ form_start(form) }}
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Service Title</label>
                            {{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'e.g. Professional House Painting'}}) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Category</label>
                                {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Price (₹)</label>
                                {{ form_widget(form.price, {'attr': {'class': 'form-control', 'placeholder': '0.00'}}) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Service Description</label>
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '5', 'placeholder': 'Tell customers why they should hire you...'}}) }}
                        </div>

                        {# Jo tamare backend mathi isPremium default false rakhvu hoy to aa field ne hide pan kari shakay #}
                        <div class="mb-3 form-check">
                            {{ form_widget(form.isPremium, {'attr': {'class': 'form-check-input'}}) }}
                            <label class="form-check-label fw-bold text-warning">Apply for Premium Listing?</label>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Publish Service</button>
                            <a href="{{ path('app_service_list') }}" class="btn btn-outline-secondary">Back to List</a>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}